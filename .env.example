# Milqu Fresh — Environment Variables Configuration
# Copy this file to .env and fill in your values.

# ── CORE SETTINGS ──────────────────────────────────────────
# Set to 'production' on Vercel and Render
NODE_ENV=development
# Port for the local server (Render uses its own PORT env var)
PORT=5001
# Your MongoDB Atlas Connection String
# Example: mongodb+srv://user:pass@cluster.mongodb.net/milqu_fresh
MONGO_URI=

# ── SECURITY ───────────────────────────────────────────────
# Long random string for JWT signing
JWT_SECRET=
# Allowed Frontend Origins (Comma separated)
# Example: https://your-site.vercel.app,https://your-custom-domain.com
CORS_ORIGIN=http://localhost:5001,http://localhost:5511,http://localhost:5512
# Set to 'false' in production to enable admin login security
ADMIN_AUTH_DISABLED=false

# ── EXTERNAL SERVICES ──────────────────────────────────────
# Cloudinary (Optional: for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Twilio (Optional: for WhatsApp/SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=whatsapp:+918767067884
ENABLE_CUSTOMER_WHATSAPP=false

# ── OPERATIONAL DEFAULTS ──────────────────────────────────
DEFAULT_PACKAGING_COST=2
DEFAULT_DELIVERY_COST=8
REPORT_RETENTION_DAYS=90
CRON_TIMEZONE=Asia/Kolkata
