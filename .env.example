NODE_ENV=production
MONGO_URI=mongodb://localhost:27017/milqu_fresh
JWT_SECRET=change-this-to-a-long-random-secret
PORT=5000
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
