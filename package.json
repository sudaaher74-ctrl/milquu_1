{
  "name": "milqu-fresh-backend",
  "version": "1.0.0",
  "description": "Backend API for Milqu Fresh dairy website",
  "main": "milqu-backend/server.js",
  "scripts": {
    "start": "node milqu-backend/server.js",
    "dev": "nodemon milqu-backend/server.js",
    "dev:frontend": "cd frontend-react && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\" --names \"backend,react\" --prefix-colors \"green,cyan\"",
    "build:frontend": "cd frontend-react && npm install && npm run build",
    "build": "npm run build:frontend && rm -rf public && cp -r frontend-react/dist public",
    "deploy": "npm run build && npm start",
    "seed-admin": "node milqu-backend/seed-admin.js"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "mongoose": "^8.23.0",
    "multer": "^2.1.0",
    "multer-storage-cloudinary": "^2.2.1",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "twilio": "^5.12.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.4"
  }
}
